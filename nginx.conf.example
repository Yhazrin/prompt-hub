# ================================================
# Prompt Hub - Nginx 配置示例
# 保存到 /etc/nginx/sites-available/prompt-hub
# 然后: sudo ln -s /etc/nginx/sites-available/prompt-hub /etc/nginx/sites-enabled/
# ================================================

server {
    listen 80;
    server_name your-domain.com;  # ← 替换为你的域名

    # 强制跳转 HTTPS（可选，Let's Encrypt 证书后开启）
    # return 301 https://$server_name$request_uri;
}

