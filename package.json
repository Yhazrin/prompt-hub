{
  "name": "prompt-hub",
  "version": "1.0.0",
  "description": "AI Prompt Hub - 飞书知识库双向同步展示站",
  "main": "server.mjs",
  "type": "module",
  "scripts": {
    "dev": "node server.mjs",
    "build": "next build",
    "start": "NODE_ENV=production node server.mjs",
    "sync": "node -e \"import('./lib/sync.mjs').then(m => m.syncAllFromWiki())\"",
    "legacy:start": "node server/index.js",
    "legacy:dev": "node --watch server/index.js"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "framer-motion": "^12.38.0",
    "multer": "^2.1.1",
    "next": "^16.2.6",
    "node-cron": "^3.0.3",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sharp": "^0.33.5",
    "swr": "^2.4.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "serve": "^14.2.4"
  }
}
